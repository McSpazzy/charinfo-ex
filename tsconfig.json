{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "module": "esnext",
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "lib",
    "rootDir": "./src",
    "declaration": true,
    "types": ["node"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
